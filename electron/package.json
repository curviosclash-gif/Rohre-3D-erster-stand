{
  "name": "curviosclash-app",
  "version": "1.0.0",
  "type": "module",
  "main": "main.js",
  "description": "CurviosClash Desktop App - Host multiplayer games",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --config electron-builder.json"
  },
  "build": {
    "appId": "com.curviosclash.app",
    "productName": "CurviosClash",
    "files": [
      "main.js",
      "preload.js",
      "../dist/**/*",
      "../server/lan-signaling.js"
    ],
    "directories": {
      "output": "../release"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
