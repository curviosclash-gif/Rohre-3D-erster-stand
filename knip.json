{
    "$schema": "https://unpkg.com/knip@5/schema.json",
    "entry": [
        "index.html",
        "src/core/main.js",
        "tests/**/*.spec.js",
        "scripts/**/*.mjs",
        "scripts/**/*.js",
        "editor/js/main.js",
        "playwright.config.js",
        "vite.config.js",
        "server/lan-signaling.js",
        "server/signaling-server.js",
        "electron/main.cjs",
        "electron/launch.cjs",
        "electron/preload.cjs",
        "electron/static-server.cjs",
        "trainer/server/TrainerServer.mjs",
        "trainer/session/TrainerSession.mjs"
    ],
    "project": [
        "src/**/*.js",
        "editor/js/**/*.js",
        "tests/**/*.js",
        "scripts/**/*.mjs",
        "server/**/*.js",
        "electron/**/*.cjs",
        "trainer/**/*.mjs"
    ],
    "ignore": [
        "tmp/**",
        ".codex_tmp/**",
        "backups/**",
        "dist/**",
        "playwright-report/**"
    ],
    "ignoreDependencies": [
        "playwright",
        "electron"
    ],
    "ignoreBinaries": [
        "powershell"
    ],
    "rules": {
        "files": "warn",
        "exports": "warn",
        "types": "warn",
        "nsExports": "off",
        "nsTypes": "off",
        "enumMembers": "off",
        "dependencies": "warn",
        "devDependencies": "warn",
        "optionalPeerDependencies": "off",
        "unlisted": "warn",
        "binaries": "warn",
        "unresolved": "warn"
    }
}
