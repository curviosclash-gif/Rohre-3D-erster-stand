{
  "name": "cuviosclash",
  "version": "0.9.0",
  "description": "Ein 3D-Arcade-Flugspiel inspiriert von klassischen Arena-Spielen",
  "main": "src/core/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "docs:check": "node scripts/docs-freshness.mjs --check",
    "docs:sync": "node scripts/docs-freshness.mjs --write",
    "training:run": "node scripts/training-run.mjs",
    "training:eval": "node scripts/training-eval.mjs",
    "training:gate": "node scripts/training-gate.mjs",
    "training:loop": "node scripts/training-loop.mjs --bridge-mode bridge --resume-checkpoint latest --resume-strict false",
    "training:e2e": "node scripts/training-e2e.mjs --bridge-mode bridge --resume-checkpoint latest --resume-strict false --with-trainer-server true",
    "smoke:selftrail": "npm run build && node scripts/self-trail-debug-smoke.mjs",
    "smoke:roundstate": "node scripts/round-state-controller-smoke.mjs",
    "bot:validate": "node scripts/bot-validation-runner.mjs",
    "benchmark:baseline": "node scripts/bot-benchmark-baseline.mjs",
    "benchmark:lifecycle": "node scripts/perf-lifecycle-measure.mjs",
    "benchmark:jitter": "node scripts/perf-jitter-matrix.mjs",
    "test:v28:regression": "playwright test tests/v28-regression.spec.js",
    "test:fast": "playwright test tests/core.spec.js tests/physics-core.spec.js",
    "test:core": "playwright test tests/core.spec.js",
    "test:gpu": "playwright test tests/gpu.spec.js",
    "test:physics": "playwright test tests/physics-core.spec.js tests/physics-hunt.spec.js tests/physics-policy.spec.js",
    "test:physics:core": "playwright test tests/physics-core.spec.js",
    "test:physics:hunt": "playwright test tests/physics-hunt.spec.js",
    "test:physics:policy": "playwright test tests/physics-policy.spec.js",
    "test:stress": "playwright test tests/stress.spec.js",
    "prepare": "husky"
  },
  "keywords": [
    "game",
    "3d",
    "threejs"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "mp4-muxer": "^5.2.2",
    "three": "^0.160.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@playwright/test": "^1.58.2",
    "husky": "^9.1.7",
    "vite": "^5.0.0",
    "ws": "^8.19.0"
  }
}
